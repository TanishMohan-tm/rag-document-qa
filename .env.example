# Copy this file to .env and fill in your actual values
# cp .env.example .env

# FREE: Get your key at https://console.groq.com (no credit card)
GROQ_API_KEY=your_groq_key_here

# OPTIONAL: Only needed if you want to use OpenAI instead of Groq
OPENAI_API_KEY=your_openai_key_here

# Storage paths (leave as default unless you change the folder structure)
UPLOAD_DIR=data/uploads
VECTOR_STORE_DIR=data/vector_stores